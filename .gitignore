# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*

# Build output
dist/
dist-ssr/
build/

# Vite / bundler caches
.vite/
*.tsbuildinfo

# Generated route tree (TanStack Router) — regenerated by `tsr generate`
# (runs in dev, build, typecheck, and CI)
src/routeTree.gen.ts

# Env — only .env.example is committed
.env
.env.*
!.env.example

# Tests / coverage
coverage/
.vitest/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
*.sw?
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Claude Code — personal overrides only
.claude/settings.local.json
# Per-developer symlinks the `skills` CLI writes into .claude/skills/ (they point
# into the ignored .agents/ install dir — committing them would dangle).
.claude/skills/
.gstack/

# Agent skills installed locally via the `skills` CLI (e.g. hallmark) — tooling,
# not FININT source. `skills-lock.json` (the manifest) is what you commit if you
# want the team to reproduce the install with `npx skills install`.
.agents/
