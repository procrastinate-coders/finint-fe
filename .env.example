# finint-fe environment — copy to .env.local and adjust.
# Only VITE_-prefixed vars reach the client bundle (Vite convention).

# Base URL of the FININT FastAPI backend. It lives on its OWN host with bare
# paths (no /api prefix — nothing to collide with).
#   prod: https://apifinint.apextrader.trade
#   dev against a local backend: http://localhost:8000
VITE_FININT_API_BASE_URL=https://apifinint.apextrader.trade

# Run the UI against MSW mock handlers instead of the real backend.
# Mocks are ON by default in `npm run dev` (the live API is still behind nginx
# basic auth and FIN-156/157 aren't built) — set VITE_API_MOCK=0 to hit the
# live backend. Ignored in production builds (prod never bundles MSW).
VITE_API_MOCK=1
